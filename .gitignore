!.vscode/extensions.json
!.vscode/tasks.json
!.vscode/launch.json
.idea/
*.swp
.DS_Store

# Docker volumes (local dev only)
data/
postgres-data/

# Logs
*.log
logs/

# Tunnel configs（含 authtoken，不可進版控）
ngrok.yml
.cloudflared/

# Uploads / generated images（本地 storage）
storage/
uploads/
generated/
