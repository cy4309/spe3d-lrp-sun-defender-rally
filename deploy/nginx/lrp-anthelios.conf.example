# =============================================================================
# 理膚寶水 LIFF 活動 — Nginx 反向代理（範例）
# =============================================================================
#
# 用途：單一 HTTPS 網域同時提供
#   - React SPA（LIFF 前端靜態檔）
#   - FastAPI（/api、/img）
#
# 使用前請複製並修改標示「TODO」的項目：
#   cp deploy/nginx/lrp-anthelios.conf.example /etc/nginx/sites-available/lrp-anthelios.conf
#
# 詳細交接說明：deploy/nginx/README.md
# =============================================================================

upstream lrp_api {
    # TODO：API 容器或本機 uvicorn 位址（建議只聽 127.0.0.1，不對外暴露 8000）
    server 127.0.0.1:8000;
    keepalive 32;
}

# TODO：正式網域（須 HTTPS；LINE LIFF Endpoint URL 填此網域根路徑）
# 例：https://anthelios-campaign.example.com/
map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

server {
    listen 80;
    listen [::]:80;
    server_name anthelios-campaign.example.com;

    # HTTP 一律導向 HTTPS
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name anthelios-campaign.example.com;

    # ----- TLS（TODO：換成實際憑證路徑，建議 Let's Encrypt）-----
    ssl_certificate     /etc/letsencrypt/live/anthelios-campaign.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/anthelios-campaign.example.com/privkey.pem;
    ssl_session_timeout 1d;
    ssl_session_cache shared:SSL:10m;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;

    # ----- 前端靜態檔（TODO：Vite build 輸出目錄）-----
    # 建置：cd apps/web && npm ci && npm run build
    # 部署：將 apps/web/dist/ 同步至此 root
    root /var/www/lrp-anthelios/web/dist;
    index index.html;

    # 上傳照片（POST /api/v1/jobs）— 依產品限制調整，建議 ≥ 10MB
    client_max_body_size 20M;

    # 安全標頭（LIFF WebView 建議保留較寬鬆的 frame 設定，依資安政策調整）
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    # ----- 共用 proxy 標頭（圖片 URL、OAuth 回呼依賴 X-Forwarded-*）-----
    # IMAGE_BASE_URL=/img 時，API 會用這些標頭組出 https://{host}/img/...

    # FastAPI 業務 API
    location /api/ {
        proxy_pass http://lrp_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header Connection "";

        proxy_connect_timeout 10s;
        proxy_send_timeout 120s;
        proxy_read_timeout 120s;
    }

    # 生成結果圖、分享圖（FastAPI StaticFiles，storage volume 掛在 API 容器 /data/images）
    location /img/ {
        proxy_pass http://lrp_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header Connection "";

        # 圖片可快取；若日後改 signed URL / CDN，可移除此 location
        expires 7d;
        add_header Cache-Control "public";
    }

    # ----- 正式環境建議關閉（APP_DEBUG=false 時 API 也不會掛載）-----
    location /docs {
        return 404;
    }
    location /openapi.json {
        return 404;
    }
    location /tools/ {
        return 404;
    }
    location /api/v1/admin/ {
        return 404;
    }

    # Vite 建置的靜態資源（含 hash，可長快取）
    location /assets/ {
        try_files $uri =404;
        expires 30d;
        add_header Cache-Control "public, immutable";
    }

    # 其他 public 檔（favicon、manifest 等）
    location ~* \.(ico|svg|png|jpg|jpeg|webp|woff2?)$ {
        try_files $uri =404;
        expires 7d;
        add_header Cache-Control "public";
    }

    # React Router — SPA fallback
    location / {
        try_files $uri $uri/ /index.html;
    }

    # 健康檢查（可給 LB 使用，不經過前端）
    location = /api/v1/health {
        proxy_pass http://lrp_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        access_log off;
    }
}

# =============================================================================
# 選用：API 獨立子網域（前後端分網域時）
# =============================================================================
# 若前端 VITE_API_BASE_URL=https://api.example.com，可另開此 server。
# LIFF Endpoint 仍指向「前端」網域；僅 XHR 打 api 子網域。
#
# server {
#     listen 443 ssl http2;
#     server_name api.anthelios-campaign.example.com;
#     ...
#     location / {
#         proxy_pass http://lrp_api;
#         ...
#     }
# }
# 此時 production .env 建議：
#   IMAGE_BASE_URL=https://api.anthelios-campaign.example.com/img
#   VITE_API_BASE_URL=https://api.anthelios-campaign.example.com
# =============================================================================
