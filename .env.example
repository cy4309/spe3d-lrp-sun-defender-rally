# ===== App =====
APP_ENV=dev
APP_DEBUG=true
APP_BASE_URL=http://localhost:8000

# ===== Database =====
POSTGRES_USER=lrp
POSTGRES_PASSWORD=lrp_dev_password
POSTGRES_DB=lrp_anthelios
DATABASE_URL=postgresql+asyncpg://lrp:lrp_dev_password@db:5432/lrp_anthelios

# ===== Redis (queue) =====
REDIS_URL=redis://redis:6379/0

# ===== LINE / LIFF =====
LIFF_ID=
LIFF_CHANNEL_ID=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# ===== Internal tokens =====
INTERNAL_API_TOKEN=please-generate-a-64-char-random-string
MACHINE_API_TOKEN_SIGNING_KEY=please-generate-a-64-char-random-string

# ===== Image storage =====
IMAGE_STORAGE_PATH=/data/images
IMAGE_BASE_URL=http://localhost:8000/img

# ===== AI / external services =====
COMFYUI_BASE_URL=http://mock-comfyui:9000
COMFYUI_API_KEY=
PICBOT_BASE_URL=

# ===== Job rules =====
JOB_RETRY_MAX=1
POLLING_INTERVAL_MS=2000
WORKER_CONCURRENCY=2

# ===== Web (Vite) =====
# 注意：VITE_ 開頭的會 bundle 進前端，請只放公開資訊
VITE_LIFF_ID=
VITE_API_BASE_URL=http://localhost:8000
VITE_CAMPAIGN_CODE=anthelios-2026-summer
# 本地開發設 true → 跳過 LINE auth 直接進 mock 模式；上線前改 false 或移除此行
VITE_MOCK_MODE=true
# 上線後填入，供 LINE 分享訊息帶入 LIFF 連結
VITE_LIFF_URL=
