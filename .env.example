# 複製為 .env：cp .env.example .env
# ngrok 範例：ngrok http 5173 → LIFF Endpoint 填 https://xxxx.ngrok-free.app

# --- Docker / DB（必填）---
POSTGRES_USER=lrp
POSTGRES_PASSWORD=change-me
POSTGRES_DB=lrp_anthelios
DATABASE_URL=postgresql+asyncpg://lrp:change-me@db:5432/lrp_anthelios
REDIS_URL=redis://redis:6379/0

# --- LINE LIFF（真實 LINE 測試必填）---
LIFF_CHANNEL_ID=
VITE_LIFF_ID=
VITE_CAMPAIGN_CODE=anthelios-2026-summer
VITE_MOCK_MODE=false

# --- API / worker（必填）---
INTERNAL_API_TOKEN=please-generate-a-64-char-random-string
IMAGE_BASE_URL=/img

# --- 選用（需要時再加）---
# APP_DEBUG=false  # 關閉後不掛 /tools 與 /api/v1/admin/stats
# PUBLIC_BASE_URL=https://xxxx.ngrok-free.app  # 必填（本地 dev）：LINE Push 取圖須 HTTPS，與 ngrok 網域一致
# APP_BASE_URL=https://your-campaign.example.com  # 正式環境 QR deep link；未設 PUBLIC_BASE_URL 時亦用於 Push 取圖
# LINE_CHANNEL_ACCESS_TOKEN=  # 生圖完成 Push 應援照至聊天室（Messaging API push）
# LINE_CHANNEL_SECRET=
# PARTNER_WEBHOOK_TOKEN=
# VITE_API_BASE_URL=
# VITE_SHARE_ASSET_BASE=https://xxxx.ngrok-free.app
# VITE_LIFF_URL=
# COMFYUI_BASE_URL=
